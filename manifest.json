{
  "manifest_version": 3,
  "name": "PolyPrompt — Folders & Prompts for Every LLM",
  "version": "0.1.1",
  "description": "Organize your ChatGPT, Claude, Gemini, and Perplexity chats into folders, and reuse the same prompt library across all of them.",
  "author": "Rouhaiseki",
  "homepage_url": "https://github.com/Rouhaiseki/polyprompt",

  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "PolyPrompt",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["lib/storage.js", "lib/adapter-base.js", "content/chatgpt.js"],
      "css": ["sidebar/sidebar.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["lib/storage.js", "lib/adapter-base.js", "content/claude.js"],
      "css": ["sidebar/sidebar.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["lib/storage.js", "lib/adapter-base.js", "content/gemini.js"],
      "css": ["sidebar/sidebar.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.perplexity.ai/*"],
      "js": ["lib/storage.js", "lib/adapter-base.js", "content/perplexity.js"],
      "css": ["sidebar/sidebar.css"],
      "run_at": "document_idle"
    }
  ]
}
